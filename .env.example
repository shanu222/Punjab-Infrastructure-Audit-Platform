# Frontend (Vite) — API base URL
# ---------------------------------------------------------------------------
# **Vercel (recommended):** set `NEXT_PUBLIC_API_URL` (HTTPS, no trailing slash).
# Do **not** mark it as "Sensitive" in Vercel — sensitive values are not exposed to the
# static build, so the URL will be missing from the bundle and API calls will fail.
#
# Vite bakes it at build time via `vite.config.ts` (`__PIAP_API_BASE__`) + `import.meta.env`.
#
# Example (HTTPS, no trailing slash):
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#
# Local dev: leave both unset to use relative `/api` + Vite proxy → http://127.0.0.1:5000
#
# Alternative name (also supported):
#   VITE_API_BASE_URL=https://api.yourdomain.com

NEXT_PUBLIC_API_URL=

# VITE_API_BASE_URL=
