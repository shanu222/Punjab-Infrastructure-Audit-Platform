# Frontend (Vite) — API base URL
# ---------------------------------------------------------------------------
# **Vercel (recommended):** set `NEXT_PUBLIC_API_URL` (same name as Next.js apps;
# Vite bakes it into the bundle at build time via `vite.config.ts` + `import.meta.env`).
#
# Example (HTTPS, no trailing slash):
#   NEXT_PUBLIC_API_URL=https://api.yourdomain.com
#
# Local dev: leave both unset to use relative `/api` + Vite proxy → http://127.0.0.1:5000
#
# Alternative name (also supported):
#   VITE_API_BASE_URL=https://api.yourdomain.com

NEXT_PUBLIC_API_URL=

# VITE_API_BASE_URL=
