# Frontend (Vite) — API base URL
# ---------------------------------------------------------------------------
# Local dev: leave empty to use relative `/api` + Vite proxy → localhost:5000
# Vercel / production: set to your public API origin, **no trailing slash**
#   Example: https://api.yourdomain.com   or   https://ec2-xx.compute.amazonaws.com
# HTTPS is required when the web app is served over HTTPS (mixed content otherwise).
#
# Vercel project → Settings → Environment Variables:
#   VITE_API_BASE_URL = https://your-api-host:5000
#
# Optional alias (either works):
# VITE_API_URL=

VITE_API_BASE_URL=

# Optional: mirror Next-style name in CI (not read by Vite unless you wire it in vite.config):
# NEXT_PUBLIC_API_URL=
