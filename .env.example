# Frontend (Vite) — API base URL for production (Vercel → EC2)
# ---------------------------------------------------------------------------
# **Preferred (Vite):** `VITE_API_BASE_URL` = your public API origin, **HTTPS**, no trailing slash.
# **Also supported:** `NEXT_PUBLIC_API_URL` (same value if you prefer Next-style naming).
#
# Do **not** mark either as "Sensitive" on Vercel — the value must be available during
# `vite build` so it can be baked into the static bundle.
#
# Example:
#   VITE_API_BASE_URL=https://api.yourdomain.com
#
# Local dev: leave both unset → relative `/api` + Vite dev proxy.

VITE_API_BASE_URL=

# NEXT_PUBLIC_API_URL=
