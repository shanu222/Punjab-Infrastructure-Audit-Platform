PORT=5000
NODE_ENV=development

MONGO_URI=mongodb://127.0.0.1:27017/piap_audit
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# --- AWS S3 (dedicated bucket, private; app uses presigned GET URLs) ---
# Bucket name example: infra-audit-platform-punjab (same region as EC2)
AWS_BUCKET_NAME=
AWS_REGION=ap-south-1

# Optional: leave blank on EC2 and attach an IAM role with s3:PutObject/GetObject on infra-audit/*
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Prefix inside bucket (must match IAM policy path): infra-audit/images|videos|reports/
S3_OBJECT_PREFIX=infra-audit

# Presigned read URL lifetime (seconds), max 604800 (7 days)
AWS_S3_SIGNED_URL_TTL_SECONDS=604800

# Optional per-type limits (bytes)
# S3_MAX_IMAGE_BYTES=
# S3_MAX_VIDEO_BYTES=
# S3_MAX_REPORT_BYTES=
