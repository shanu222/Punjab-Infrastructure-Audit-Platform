PORT=5000
NODE_ENV=development

# JSON logs to stdout — ship with CloudWatch agent / ECS log driver (LOG_GROUP_NAME in agent config).
LOG_LEVEL=info

MONGO_URI=mongodb://127.0.0.1:27017/piap_audit
JWT_SECRET=replace-with-long-random-secret-min-32-chars
JWT_EXPIRES_IN=7d

# Comma-separated allowed browser origins (Vercel preview + production).
# Example: https://punjab-infrastructure-audit-platform.vercel.app,https://punjab-infrastructure-audit-platform-git-main-ORG.vercel.app
# Use * only without credentials (not recommended for this API).
CORS_ORIGIN=

# Bind address (default 0.0.0.0 so EC2 accepts traffic from outside localhost)
# BIND_HOST=0.0.0.0

# --- AWS S3 (dedicated bucket, private; app uses presigned GET URLs) ---
# Bucket name example: infra-audit-platform-punjab (same region as EC2)
# Dedicated bucket (block public access; use IAM + presigned URLs)
AWS_BUCKET_NAME=infra-audit-platform-punjab
AWS_REGION=ap-south-1

# Optional: leave blank on EC2 and attach an IAM role with s3:PutObject/GetObject on infra-audit/*
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# Prefix inside bucket (must match IAM policy path): infra-audit/images|videos|reports/
S3_OBJECT_PREFIX=infra-audit

# Presigned read URL lifetime (seconds), max 604800 (7 days)
AWS_S3_SIGNED_URL_TTL_SECONDS=604800

# Optional per-type limits (bytes)
# S3_MAX_IMAGE_BYTES=
# S3_MAX_VIDEO_BYTES=
# S3_MAX_REPORT_BYTES=
